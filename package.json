    "@langchain/openai": "^1.3.0",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.8.0",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.13",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
